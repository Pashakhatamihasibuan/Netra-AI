# Supabase project credentials (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only, used in API routes / server components that bypass RLS deliberately (none currently)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Server-only secret used to sign student access-code sessions (set a long random string in production)
STUDENT_SECRET=change-me-to-a-long-random-string
# Kode rahasia untuk mendaftarkan akun Kepala Sekolah (admin) lewat tab
# "Kep. Sekolah" di halaman login. Bagikan hanya ke pihak sekolah yang
# berwenang. Tanpa variabel ini diset, pendaftaran admin dinonaktifkan.
SCHOOL_ADMIN_CODE=set-a-long-random-secret
